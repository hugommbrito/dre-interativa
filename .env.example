# Senha exigida pelo frontend para acessar e enviar dados
DRE_PASSWORD=sua_senha_aqui

# Chave da API da Anthropic — usada pela rota /api/analyze para análise IA
ANTHROPIC_API_KEY=sk-ant-...

# Geradas automaticamente ao vincular um banco KV na Vercel (Storage → KV)
KV_REST_API_URL=https://seu-banco.upstash.io
KV_REST_API_TOKEN=seu_token_aqui
KV_REST_API_READ_ONLY_TOKEN=seu_token_readonly_aqui
